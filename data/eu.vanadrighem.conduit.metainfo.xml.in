<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>eu.vanadrighem.conduit</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Conduit</name>
  <summary>Native Slack client</summary>
  <description>
    <p>
      Conduit is a lightweight GNOME desktop client for Slack. It uses GTK and libadwaita for a native interface, stores Slack tokens in the system keyring, and keeps network work off the UI thread.
    </p>
  </description>

  <developer id="eu.vanadrighem">
    <name>Vincent van Adrighem</name>
  </developer>

  <url type="homepage">https://github.com/adrighem/Conduit</url>
  <url type="vcs-browser">https://github.com/adrighem/Conduit</url>
  <url type="bugtracker">https://github.com/adrighem/Conduit/issues</url>
  <url type="contribute">https://github.com/adrighem/Conduit</url>

  <translation type="gettext">conduit</translation>
  <!-- All graphical applications having a desktop file must have this tag in the MetaInfo.
     If this is present, appstreamcli compose will pull icons, keywords and categories from the desktop file. -->
  <launchable type="desktop-id">eu.vanadrighem.conduit.desktop</launchable>
  <!-- Use the OARS website (https://hughsie.github.io/oars/generate.html) to generate these and make sure to use oars-1.1 -->
  <content_rating type="oars-1.1" />

  <branding>
    <color type="primary" scheme_preference="light">#996b50</color>
    <color type="primary" scheme_preference="dark">#543b2f</color>
  </branding>

  <releases>
    <release version="0.3.0" date="2026-07-23"> <!-- x-release-please-version-date -->
      <url type="details">https://github.com/adrighem/Conduit/releases/tag/v0.3.0</url> <!-- x-release-please-version -->
      <description translate="no">
        <p>See the linked release notes for the changes in this version.</p>
      </description>
    </release>
  </releases>

</component>
