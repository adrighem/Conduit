#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export DEB_CARGO_HOME = $(CURDIR)/obj-$(DEB_HOST_GNU_TYPE)/cargo-home

%:
	dh $@ --buildsystem=meson

override_dh_auto_configure:
	dh_auto_configure --buildsystem=meson -- \
		--buildtype=release \
		-Dheadless_tests=disabled \
		-Dnative_media=disabled \
		-Dscreen_share=disabled

override_dh_auto_build:
	CARGO_HOME="$(DEB_CARGO_HOME)" cargo fetch --locked
	CARGO_NET_OFFLINE=true dh_auto_build --buildsystem=meson

override_dh_auto_test:
	CARGO_NET_OFFLINE=true dh_auto_test --buildsystem=meson
