{
    "id" : "eu.vanadrighem.conduit",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "sdk-extensions" : [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command" : "conduit",
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=pulseaudio",
        "--device=dri",
        "--socket=wayland",
        "--talk-name=org.freedesktop.secrets"
    ],
    "build-options" : {
        "append-path" : "/usr/lib/sdk/rust-stable/bin"
    },
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules" : [
        {
            "name" : "conduit",
            "builddir" : true,
            "buildsystem" : "meson",
            "build-options" : {
                "env" : {
                    "CARGO_NET_OFFLINE" : "true"
                }
            },
            "sources" : [
                {
                    "type" : "dir",
                    "path" : "../.."
                },
                "cargo-sources.json",
                {
                    "type" : "shell",
                    "commands" : [
                        "mkdir -p .cargo",
                        "cp -vf cargo/config .cargo/config.toml"
                    ]
                }
            ],
            "config-opts" : [
                "--libdir=lib",
                "--buildtype=release",
                "-Dnative_media=enabled",
                "-Dscreen_share=enabled"
            ]
        }
    ]
}
